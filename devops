#!/usr/bin/env bash
# =====================================================================
# ERPGo SaaS — DevOps CLI Orchestrator
# =====================================================================
# Single command entry point for database seeding operations.
#
# Usage:
#   ./devops seed --env=dev --reset
#   ./devops seed --env=staging --service=core
#   ./devops seed --dry-run
#   ./devops status
#   ./devops health
#
# Requirements:
#   - Docker + Docker Compose (for containerized mode)
#   - PHP 8.1+ (for local mode)
# =====================================================================

set -euo pipefail

# ── Constants ──────────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="${SCRIPT_DIR}"
DOCKER_COMPOSE_FILE="${PROJECT_ROOT}/docker-compose.yml"
LOG_DIR="${PROJECT_ROOT}/storage/logs"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
LOG_FILE="${LOG_DIR}/devops_${TIMESTAMP}.log"

# ── Colors ─────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
GRAY='\033[0;37m'
NC='\033[0m' # No Color
BOLD='\033[1m'

# ── Logging Functions ──────────────────────────────────────────────────
log() {
    local level="$1"
    shift
    local message="$*"
    local ts=$(date '+%Y-%m-%d %H:%M:%S')
    echo "[${ts}] [${level}] ${message}" >> "${LOG_FILE}" 2>/dev/null || true
}

info()    { echo -e "${CYAN}ℹ ${NC}${WHITE}$*${NC}"; log "INFO" "$*"; }
success() { echo -e "${GREEN}✅ ${NC}${WHITE}$*${NC}"; log "SUCCESS" "$*"; }
warn()    { echo -e "${YELLOW}⚠️  ${NC}${YELLOW}$*${NC}"; log "WARN" "$*"; }
error()   { echo -e "${RED}❌ ${NC}${RED}$*${NC}"; log "ERROR" "$*"; }

# ── Banner ─────────────────────────────────────────────────────────────
show_banner() {
    echo -e ""
    echo -e "${CYAN}╔═══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${NC}  ${GREEN}🛠️  ERPGo SaaS — DevOps Orchestrator${NC}                    ${CYAN}║${NC}"
    echo -e "${CYAN}║${NC}  ${GRAY}Automated Database Seeding & Management${NC}                 ${CYAN}║${NC}"
    echo -e "${CYAN}╚═══════════════════════════════════════════════════════════╝${NC}"
    echo -e ""
}

# ── Help ───────────────────────────────────────────────────────────────
show_help() {
    show_banner
    echo -e "${BOLD}USAGE:${NC}"
    echo -e "  ./devops <command> [options]"
    echo -e ""
    echo -e "${BOLD}COMMANDS:${NC}"
    echo -e "  ${GREEN}seed${NC}       Run database seeding orchestration"
    echo -e "  ${GREEN}status${NC}     Show status of all database services"
    echo -e "  ${GREEN}health${NC}     Run health checks on all databases"
    echo -e "  ${GREEN}logs${NC}       Show recent seed execution logs"
    echo -e "  ${GREEN}report${NC}     Show latest execution report"
    echo -e "  ${GREEN}help${NC}       Show this help message"
    echo -e ""
    echo -e "${BOLD}SEED OPTIONS:${NC}"
    echo -e "  ${YELLOW}--env=ENV${NC}        Target environment: dev|staging|production (default: dev)"
    echo -e "  ${YELLOW}--reset${NC}          Drop and recreate all tables before seeding"
    echo -e "  ${YELLOW}--fresh${NC}          Run migrate:fresh before seeding"
    echo -e "  ${YELLOW}--service=NAME${NC}   Seed only a specific service"
    echo -e "  ${YELLOW}--dry-run${NC}        Show execution plan without running"
    echo -e "  ${YELLOW}--skip-health${NC}    Skip database health checks"
    echo -e "  ${YELLOW}--force${NC}          Force execution without confirmation"
    echo -e "  ${YELLOW}--no-migrate${NC}     Skip migrations, only run seeders"
    echo -e "  ${YELLOW}--docker${NC}         Run inside Docker containers"
    echo -e "  ${YELLOW}--local${NC}          Run locally with PHP (default)"
    echo -e ""
    echo -e "${BOLD}EXAMPLES:${NC}"
    echo -e "  ${GRAY}# Full seed for development with reset${NC}"
    echo -e "  ./devops seed --env=dev --reset"
    echo -e ""
    echo -e "  ${GRAY}# Seed only core service${NC}"
    echo -e "  ./devops seed --service=core"
    echo -e ""
    echo -e "  ${GRAY}# Preview what would happen${NC}"
    echo -e "  ./devops seed --dry-run"
    echo -e ""
    echo -e "  ${GRAY}# Seed via Docker containers${NC}"
    echo -e "  ./devops seed --env=dev --docker --reset"
    echo -e ""
}

# ── Prerequisite Checks ───────────────────────────────────────────────
check_prerequisites() {
    local mode="$1"

    if [[ "$mode" == "docker" ]]; then
        if ! command -v docker &> /dev/null; then
            error "Docker is not installed or not in PATH"
            exit 1
        fi
        if ! command -v docker compose &> /dev/null && ! command -v docker-compose &> /dev/null; then
            error "Docker Compose is not installed"
            exit 1
        fi
        if [[ ! -f "$DOCKER_COMPOSE_FILE" ]]; then
            error "docker-compose.yml not found at: $DOCKER_COMPOSE_FILE"
            exit 1
        fi
    else
        if ! command -v php &> /dev/null; then
            error "PHP is not installed or not in PATH"
            exit 1
        fi
    fi

    # Ensure log directory exists
    mkdir -p "${LOG_DIR}"
}

# ── Parse Arguments ──────────────────────────────────────────────────
parse_seed_args() {
    ENV="dev"
    RESET=""
    FRESH=""
    SERVICE=""
    DRY_RUN=""
    SKIP_HEALTH=""
    FORCE=""
    NO_MIGRATE=""
    MODE="local"

    for arg in "$@"; do
        case $arg in
            --env=*)       ENV="${arg#*=}" ;;
            --reset)       RESET="--reset" ;;
            --fresh)       FRESH="--fresh" ;;
            --service=*)   SERVICE="--service=${arg#*=}" ;;
            --dry-run)     DRY_RUN="--dry-run" ;;
            --skip-health) SKIP_HEALTH="--skip-health" ;;
            --force)       FORCE="--force" ;;
            --no-migrate)  NO_MIGRATE="--no-migrate" ;;
            --docker)      MODE="docker" ;;
            --local)       MODE="local" ;;
            *)             warn "Unknown option: $arg" ;;
        esac
    done
}

# ── Seed Command (Local Mode) ────────────────────────────────────────
seed_local() {
    info "Running in LOCAL mode..."
    info "Environment: ${ENV}"

    cd "${PROJECT_ROOT}"

    local cmd="php artisan seed:orchestrate --target-env=${ENV}"
    [[ -n "$RESET" ]]       && cmd+=" ${RESET}"
    [[ -n "$FRESH" ]]       && cmd+=" ${FRESH}"
    [[ -n "$SERVICE" ]]     && cmd+=" ${SERVICE}"
    [[ -n "$DRY_RUN" ]]     && cmd+=" ${DRY_RUN}"
    [[ -n "$SKIP_HEALTH" ]] && cmd+=" ${SKIP_HEALTH}"
    [[ -n "$FORCE" ]]       && cmd+=" ${FORCE}"
    [[ -n "$NO_MIGRATE" ]]  && cmd+=" ${NO_MIGRATE}"

    info "Executing: ${cmd}"
    echo -e ""

    eval "${cmd}" 2>&1 | tee -a "${LOG_FILE}"
    local exit_code=${PIPESTATUS[0]}

    echo -e ""
    if [[ $exit_code -eq 0 ]]; then
        success "Seeding completed successfully!"
    else
        error "Seeding failed with exit code: ${exit_code}"
    fi

    info "Full log saved to: ${LOG_FILE}"
    return $exit_code
}

# ── Seed Command (Docker Mode) ───────────────────────────────────────
seed_docker() {
    info "Running in DOCKER mode..."
    info "Environment: ${ENV}"

    local compose_cmd
    if command -v "docker compose" &> /dev/null 2>&1; then
        compose_cmd="docker compose"
    else
        compose_cmd="docker-compose"
    fi

    # Step 1: Ensure services are running
    info "Ensuring database services are running..."
    ${compose_cmd} -f "${DOCKER_COMPOSE_FILE}" up -d \
        core-db billing-db approvals-db mrp-db quality-db maintenance-db \
        chatgpt-db hotel-db traceability-db cropplanning-db cooperative-db \
        hedging-db hrops-db operations-db platform-db industry-db btp-db \
        integrations-db saas-db redis 2>&1 | tee -a "${LOG_FILE}"

    # Step 2: Wait for databases to be healthy
    info "Waiting for databases to be healthy..."
    local max_wait=120
    local waited=0
    while [[ $waited -lt $max_wait ]]; do
        local healthy_count
        healthy_count=$(${compose_cmd} -f "${DOCKER_COMPOSE_FILE}" ps --format json 2>/dev/null | grep -c '"healthy"' || echo "0")
        if [[ $healthy_count -ge 19 ]]; then
            success "All databases are healthy!"
            break
        fi
        echo -ne "\r  ⏳ Waiting for databases... (${waited}s / ${max_wait}s)"
        sleep 5
        waited=$((waited + 5))
    done
    echo -e ""

    if [[ $waited -ge $max_wait ]]; then
        warn "Timeout waiting for all databases. Proceeding anyway..."
    fi

    # Step 3: Run the orchestrator inside the core container
    info "Executing seed orchestrator in core container..."

    local artisan_args="seed:orchestrate --target-env=${ENV}"
    [[ -n "$RESET" ]]       && artisan_args+=" ${RESET}"
    [[ -n "$FRESH" ]]       && artisan_args+=" ${FRESH}"
    [[ -n "$SERVICE" ]]     && artisan_args+=" ${SERVICE}"
    [[ -n "$DRY_RUN" ]]     && artisan_args+=" ${DRY_RUN}"
    [[ -n "$SKIP_HEALTH" ]] && artisan_args+=" ${SKIP_HEALTH}"
    [[ -n "$FORCE" ]]       && artisan_args+=" ${FORCE}"
    [[ -n "$NO_MIGRATE" ]]  && artisan_args+=" ${NO_MIGRATE}"

    ${compose_cmd} -f "${DOCKER_COMPOSE_FILE}" exec -T core \
        php artisan ${artisan_args} 2>&1 | tee -a "${LOG_FILE}"

    local exit_code=${PIPESTATUS[0]}

    echo -e ""
    if [[ $exit_code -eq 0 ]]; then
        success "Docker seeding completed successfully!"
    else
        error "Docker seeding failed with exit code: ${exit_code}"
    fi

    info "Full log saved to: ${LOG_FILE}"
    return $exit_code
}

# ── Status Command ───────────────────────────────────────────────────
cmd_status() {
    show_banner
    info "Checking database services status..."
    echo -e ""

    local compose_cmd
    if command -v "docker compose" &> /dev/null 2>&1; then
        compose_cmd="docker compose"
    else
        compose_cmd="docker-compose"
    fi

    if [[ -f "$DOCKER_COMPOSE_FILE" ]]; then
        ${compose_cmd} -f "${DOCKER_COMPOSE_FILE}" ps --format "table {{.Name}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || \
        ${compose_cmd} -f "${DOCKER_COMPOSE_FILE}" ps 2>/dev/null || \
        warn "Could not get Docker status. Are containers running?"
    else
        warn "docker-compose.yml not found. Cannot check container status."
    fi
}

# ── Health Command ───────────────────────────────────────────────────
cmd_health() {
    show_banner
    info "Running health checks on all databases..."
    echo -e ""

    local services=(
        "core:core-db:3306:core:core:secret"
        "billing:billing-db:3306:billing:billing:secret"
        "approvals:approvals-db:3306:approvals:approvals:secret"
        "mrp:mrp-db:3306:mrp:mrp:secret"
        "quality:quality-db:3306:quality:quality:secret"
        "maintenance:maintenance-db:3306:maintenance:maintenance:secret"
        "chatgpt:chatgpt-db:3306:chatgpt:chatgpt:secret"
        "hotel:hotel-db:3306:hotel:hotel:secret"
        "traceability:traceability-db:3306:traceability:traceability:secret"
        "cropplanning:cropplanning-db:3306:cropplanning:cropplanning:secret"
        "cooperative:cooperative-db:3306:cooperative:cooperative:secret"
        "hedging:hedging-db:3306:hedging:hedging:secret"
        "hrops:hrops-db:3306:hrops:hrops:secret"
        "operations:operations-db:3306:operations:operations:secret"
        "platform:platform-db:3306:platform:platform:secret"
        "industry:industry-db:3306:industry:industry:secret"
        "btp:btp-db:3306:btp:btp:secret"
        "integrations:integrations-db:3306:integrations:integrations:secret"
        "saas:saas-db:3306:saas:saas:secret"
    )

    local total=${#services[@]}
    local healthy=0
    local unhealthy=0

    printf "  %-20s %-15s %-30s\n" "SERVICE" "STATUS" "DATABASE"
    printf "  %-20s %-15s %-30s\n" "───────────────────" "──────────────" "─────────────────────────────"

    for svc in "${services[@]}"; do
        IFS=':' read -r name host port db user pass <<< "$svc"

        if php -r "
            try {
                \$pdo = new PDO('mysql:host=${host};port=${port};dbname=${db}', '${user}', '${pass}', [PDO::ATTR_TIMEOUT => 5]);
                \$pdo->query('SELECT 1');
                echo 'OK';
            } catch (Exception \$e) {
                echo 'FAIL';
            }
        " 2>/dev/null | grep -q "OK"; then
            printf "  %-20s ${GREEN}%-15s${NC} %-30s\n" "$name" "✅ Healthy" "${db}@${host}:${port}"
            healthy=$((healthy + 1))
        else
            printf "  %-20s ${RED}%-15s${NC} %-30s\n" "$name" "❌ Down" "${db}@${host}:${port}"
            unhealthy=$((unhealthy + 1))
        fi
    done

    echo -e ""
    echo -e "  ${BOLD}Summary:${NC} ${GREEN}${healthy} healthy${NC} / ${RED}${unhealthy} down${NC} / ${total} total"
    echo -e ""
}

# ── Logs Command ─────────────────────────────────────────────────────
cmd_logs() {
    show_banner
    info "Recent seed execution logs:"
    echo -e ""

    if [[ -d "${LOG_DIR}" ]]; then
        local latest_logs
        latest_logs=$(ls -1t "${LOG_DIR}"/devops_*.log 2>/dev/null | head -5)

        if [[ -n "$latest_logs" ]]; then
            while IFS= read -r logfile; do
                local basename
                basename=$(basename "$logfile")
                local size
                size=$(du -sh "$logfile" 2>/dev/null | cut -f1)
                echo -e "  📄 ${YELLOW}${basename}${NC} (${size})"
            done <<< "$latest_logs"

            echo -e ""
            info "To view a log: cat ${LOG_DIR}/<filename>"
        else
            warn "No seed logs found."
        fi
    else
        warn "Log directory not found: ${LOG_DIR}"
    fi
}

# ── Report Command ───────────────────────────────────────────────────
cmd_report() {
    show_banner
    info "Latest seed execution report:"
    echo -e ""

    local latest_report
    latest_report=$(ls -1t "${LOG_DIR}"/seed-report-*.json 2>/dev/null | head -1)

    if [[ -n "$latest_report" ]]; then
        if command -v python3 &> /dev/null; then
            python3 -m json.tool "$latest_report"
        elif command -v jq &> /dev/null; then
            jq '.' "$latest_report"
        else
            cat "$latest_report"
        fi
    else
        warn "No seed reports found."
        info "Run './devops seed --env=dev' to generate a report."
    fi
}

# ══════════════════════════════════════════════════════════════════════
# MAIN ENTRY POINT
# ══════════════════════════════════════════════════════════════════════
main() {
    # Ensure log dir exists
    mkdir -p "${LOG_DIR}" 2>/dev/null || true

    local command="${1:-help}"
    shift 2>/dev/null || true

    case "$command" in
        seed)
            show_banner
            parse_seed_args "$@"
            check_prerequisites "${MODE}"

            if [[ "$MODE" == "docker" ]]; then
                seed_docker
            else
                seed_local
            fi
            ;;
        status)
            cmd_status
            ;;
        health)
            check_prerequisites "local"
            cmd_health
            ;;
        logs)
            cmd_logs
            ;;
        report)
            cmd_report
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            error "Unknown command: ${command}"
            show_help
            exit 1
            ;;
    esac
}

main "$@"
